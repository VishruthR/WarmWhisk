openwhisk_tmp_dir: "{{ lookup('env', 'OPENWHISK_TMP_DIR')|default('/tmp' if ansible_distribution == 'MacOSX' else '/var/tmp', true) }}"
config_root_dir: "{{ openwhisk_tmp_dir }}/wskconf"
whisk_logs_dir: "{{ openwhisk_tmp_dir }}/wsklogs"
coverage_enabled: "{{ lookup('env', 'GRADLE_COVERAGE') | default('false', true) | bool}}"
coverage_logs_dir: "{{ openwhisk_tmp_dir }}/wskcov"
docker_registry: ""
docker_dns: ""
runtimes_bypass_pull_for_local_images: true
invoker_use_runc: "{{ ansible_distribution != 'MacOSX' }}"

db_prefix: whisk_local_

# API GW connection configuration
apigw_auth_user: ""
apigw_auth_pwd: ""
apigw_host_v2: "http://{{ groups['apigateway']|first }}:{{apigateway.port.api}}/v2"

invoker_allow_multiple_instances: true

# Set kafka configuration
kafka_heap: '512m'
kafka_topics_completed_retentionBytes: 104857600
kafka_topics_completed_retentionMS: 300000
kafka_topics_health_retentionBytes: 104857600
kafka_topics_health_retentionMS: 300000
kafka_topics_invoker_retentionBytes: 104857600
kafka_topics_invoker_retentionMS: 300000

env_hosts_dir: "{{ playbook_dir }}/environments/vm"
ansible_python_interpreter: "/usr/bin/python"

container_pool_pekko_client: true
scheduler_enable: false
# Round-robin over invokers (same capacity model as sharding).
controller_loadbalancer_spi: org.apache.openwhisk.core.loadBalancer.RoundRobinPoolBalancer
controller_entitlement_spi: org.apache.openwhisk.core.entitlement.LocalEntitlementProvider
invokerReactive_spi: org.apache.openwhisk.core.invoker.InvokerWASM
invokerServer_spi: org.apache.openwhisk.core.invoker.DefaultInvokerServer
invoker_health_test_action_name: "invokerHealthTestActionWASM"
runtimes_enable_concurrency: true
limit_action_concurrency_max: 500
namespace_default_limit_action_concurrency_max: 500

# Arbitrary rate limits since we are benchmarking
limit_invocations_per_minute: 10000
limit_invocations_concurrent: 50000
limit_action_concurrency_max: 2000
namespace_default_limit_action_concurrency_max: 2000
invoker_user_memory: "8192m"

# Metrics: Ansible sets METRICS_* on containers; these override application.conf (see whisk.metrics in application.conf)
metrics_kamon: true
metrics_kamon_tags: true
# Publish activation events to Kafka for the user-events service (CONFIG_whisk_userEvents_enabled)
user_events_enabled: true